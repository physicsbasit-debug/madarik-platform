# Phase 4-A2b: Gemini scientific translation provider.
# Copy this file to backend/.env, replace the placeholder key, and never commit backend/.env.

MADARIK_AI_PROVIDER=gemini
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
MADARIK_AI_EXTERNAL_ENABLED=true
MADARIK_AI_TIMEOUT_SECONDS=45
MADARIK_AI_MAX_INPUT_CHARS=4000
MADARIK_AI_MAX_OUTPUT_TOKENS=1200
MADARIK_AI_TEMPERATURE=0.1

# Alternative: OpenAI official provider through the Responses API.
# MADARIK_AI_PROVIDER=openai
# MADARIK_AI_API_KEY=replace-with-your-openai-api-key
# MADARIK_AI_MODEL=gpt-5.6-terra
# MADARIK_AI_BASE_URL=https://api.openai.com/v1

# Alternative: OpenAI-compatible service through Chat Completions.
# MADARIK_AI_PROVIDER=openai-compatible
# MADARIK_AI_API_KEY=replace-with-your-provider-api-key
# MADARIK_AI_BASE_URL=https://your-provider.example/v1
# MADARIK_AI_MODEL=your-model-id
