# Phase 4-A1: OpenAI official provider through the Responses API.
# Copy this file to backend/.env, then replace the placeholder key.

MADARIK_AI_PROVIDER=openai
MADARIK_AI_API_KEY=replace-with-your-openai-api-key
MADARIK_AI_MODEL=gpt-5.6-terra
MADARIK_AI_BASE_URL=https://api.openai.com/v1
MADARIK_AI_EXTERNAL_ENABLED=true
MADARIK_AI_TIMEOUT_SECONDS=45
MADARIK_AI_MAX_INPUT_CHARS=4000
MADARIK_AI_MAX_OUTPUT_TOKENS=1200
MADARIK_AI_TEMPERATURE=0.1

# Alternative OpenAI-compatible service:
# MADARIK_AI_PROVIDER=openai-compatible
# MADARIK_AI_BASE_URL=https://your-provider.example/v1
# MADARIK_AI_MODEL=your-model-id
